# =============================================================================
# Agent Tools Kit — 环境变量配置
# =============================================================================
# 复制此文件为 .env 并根据需要修改：
#   cp .env.example .env          # Linux / macOS
#   copy .env.example .env         # Windows
#
# 不创建 .env 也可以用系统环境变量（或接受所有默认值）。
# 注意：.env 文件不应提交到版本控制（已在 .gitignore 中排除）。
# =============================================================================

# ---------------------------------------------------------------------------
# 数据库路径
# ---------------------------------------------------------------------------
# SQLite 数据库文件的存放位置。支持相对路径（相对于项目根目录）或绝对路径。
# 默认值: data/toolkit.db
# TOOLKIT_DB=data/toolkit.db

# ---------------------------------------------------------------------------
# API 访问密钥（可选）
# ---------------------------------------------------------------------------
# 设置后将启用 API Key 鉴权，所有 REST API 请求（/api/health 和 /mcp 除外）
# 都需要在 HTTP Header 中携带 X-API-Key。
# 留空则不启用鉴权。
# API_KEY=

# ---------------------------------------------------------------------------
# 日志配置（可选）
# ---------------------------------------------------------------------------
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL（默认 INFO）
# LOG_LEVEL=INFO
# 是否使用 JSON 结构化日志（默认 false，使用人类可读格式）
# LOG_STRUCTURED=false
# 日志文件路径（可选，不设置则只输出到控制台）
# LOG_FILE=logs/app.log

# ---------------------------------------------------------------------------
# CORS 配置（可选）
# ---------------------------------------------------------------------------
# 允许的跨域来源，逗号分隔。默认 *（允许所有来源，适合个人内网使用）
# 生产环境建议设置为具体域名，如 http://localhost:3000,https://app.example.com
# CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# API 限流配置（可选）
# ---------------------------------------------------------------------------
# 每分钟每个 IP 最大请求数，0 表示不限制（默认 60）
# RATE_LIMIT_PER_MINUTE=60

# ---------------------------------------------------------------------------
# 数据备份配置（可选）
# ---------------------------------------------------------------------------
# 备份文件存储目录（默认 data/backups）
# BACKUP_DIR=data/backups
# 保留的备份文件数量，0 表示不限制（默认 7）
# BACKUP_RETENTION=7
