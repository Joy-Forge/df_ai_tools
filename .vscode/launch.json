{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🔧 1. FastAPI Dev Server (热重载)",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "src.main:app",
                "--reload",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "jinja": true,
            "justMyCode": true,
            "console": "integratedTerminal",
            "env": {
                "PYTHONUNBUFFERED": "1"
            }
        },
        {
            "name": "🧪 2. Run All Tests",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/",
                "-v",
                "--tb=short"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "🐳 3. Docker: Build & Run",
            "type": "python",
            "request": "launch",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\windows\\run-docker.ps1"
            ],
            "justMyCode": true
        },
        {
            "name": "📦 4. Generate Deploy Package",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}\\scripts\\deploy\\generate-deploy.py",
            "args": [],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "🏷️ 5. Release (打标签发布)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}\\scripts\\release.py",
            "args": [],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
